# Database
DATABASE_URL=postgresql+asyncpg://beatclaude:beatclaude@db:5432/beatclaude
DATABASE_URL_SYNC=postgresql://beatclaude:beatclaude@db:5432/beatclaude
POSTGRES_USER=beatclaude
POSTGRES_PASSWORD=beatclaude
